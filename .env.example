# Monsoon — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# RPC URLs (get from Alchemy, Infura, or QuickNode)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OP_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Solana RPC URLs
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

# Wallet private keys (NEVER share these)
# WALLET_1_KEY=0x...
# WALLET_2_KEY=0x...
# WALLET_3_KEY=0x...
# WALLET_4_KEY=0x...
# WALLET_5_KEY=0x...
